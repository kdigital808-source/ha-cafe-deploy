// VIEW: DISPLAY — shows latest posted plan, read-only
// ═══════════════════════════════════════════════════════════════
async function renderDisplay() {
  const target = document.getElementById('display-content');
  const latest = await loadLatestPlan();

  // A plan must (a) exist, (b) have items, and (c) still be within its lifespan (until 8pm of target date)
  if (!latest || !latest.items || latest.items.length === 0 || !isPlanActive(latest)) {
    target.innerHTML = `
      <div class="day-banner">
        <div class="day-banner-greeting">${greeting()}</div>
        <div class="day-banner-date">No active prep list</div>
        <div class="day-banner-sub">Tap "+ New prep list" to set up tomorrow's prep</div>
      </div>
      <div class="empty-state">
        <div class="empty-state-title">Awaiting prep list</div>
        <div class="empty-state-text">Nothing posted yet. The cook of the day plans tomorrow's prep here.</div>
        <button class="empty-state-cta" onclick="switchView('plan')">+ New prep list</button>
      </div>
    `;
    return;
  }

  const groups = { asap: [], second: [], time: [] };
  latest.items.forEach(it => {
    if (groups[it.priority]) groups[it.priority].push(it);
  });
  const groupLabels = {
    asap: { label: 'ASAP', dot: 'asap' },
    second: { label: '2nd Priority', dot: 'second' },
    time: { label: 'If You Have Time', dot: 'time' }
  };

  // Clearer label: "Today's prep" / "Tomorrow's prep" / specific date if neither
  const today = todayKey();
  const tomorrow = tomorrowKey();
  let dateLabel;
  if (latest.targetDate === today) dateLabel = `Today's prep · ${shortDate(latest.targetDate)}`;
  else if (latest.targetDate === tomorrow) dateLabel = `Tomorrow's prep · ${shortDate(latest.targetDate)}`;
  else dateLabel = prettyDate(latest.targetDate);

  let html = `
    <div class="day-banner">
      <div class="day-banner-greeting">${greeting()}</div>
      <div class="day-banner-date">${dateLabel}</div>
      <div class="day-banner-sub">${latest.postedBy ? `By <strong>@${latest.postedBy}</strong> · ` : ''}${formatPostedTime(latest.postedAt)} · ${latest.items.length} items</div>
    </div>
  `;

  if (latest.instructions && latest.instructions.trim()) {
    html += `
      <div class="instructions-banner">
        <div class="instructions-banner-label">📋 Note from ${latest.postedBy ? '@' + latest.postedBy : 'previous cook'}</div>
        <div class="instructions-banner-text">${escapeHtml(latest.instructions)}</div>
      </div>
    `;
  }

  ['asap', 'second', 'time'].forEach(p => {
    if (groups[p].length === 0) return;
    const meta = groupLabels[p];
    
    // Sub-group by list (line vs grab-and-go) within each priority
    const byList = { line: [], grab: [] };
    groups[p].forEach(item => {
      if (byList[item.list]) byList[item.list].push(item);
    });
    
    let listsHtml = '';
    [['line', 'LINE PREP'], ['grab', "GRAB & GO'S"]].forEach(([key, label]) => {
      if (byList[key].length === 0) return;
      listsHtml += `
        <div class="compact-list-group">
          <div class="compact-list-label compact-list-${key}">${label}</div>
          <ul class="compact-list">
            ${byList[key].map(item => `<li>${escapeHtml(item.name)}</li>`).join('')}
          </ul>
        </div>
      `;
    });
    
    html += `
      <div class="priority-section compact">
        <div class="priority-header">
          <div class="priority-title">
            <span class="priority-dot ${meta.dot}"></span>
            <span>${meta.label}</span>
          </div>
          <div class="priority-count">${groups[p].length}</div>
        </div>
        <div class="compact-section-body">
          ${listsHtml}
        </div>
      </div>
    `;
  });

  target.innerHTML = html;
}

