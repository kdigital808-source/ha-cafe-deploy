// STORAGE — Netlify Functions backend (Blobs), shared across all cooks
// ═══════════════════════════════════════════════════════════════
const STORAGE_API = '/.netlify/functions/store';
const memStore = {};

async function storageGet(key) {
  try {
    const res = await fetch(`${STORAGE_API}?key=${encodeURIComponent(key)}`);
    if (!res.ok) throw new Error('fetch failed');
    const data = await res.json();
    if (data && data.value !== undefined && data.value !== null) {
      try { localStorage.setItem(`ha:${key}`, data.value); } catch {}
      return data.value;
    }
    return null;
  } catch (e) {
    console.warn('Network get failed, trying localStorage', e.message);
    try {
      const v = localStorage.getItem(`ha:${key}`);
      if (v !== null) return v;
    } catch {}
    return memStore[key] || null;
  }
}

async function storageSet(key, value) {
  memStore[key] = value;
  try { localStorage.setItem(`ha:${key}`, value); } catch {}
  try {
    const res = await fetch(STORAGE_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key, value }),
    });
    if (!res.ok) throw new Error('save failed');
    return { ok: true, mode: 'shared' };
  } catch (e) {
    console.warn('Network save failed, kept locally', e.message);
    return { ok: true, mode: 'local' };
  }
}
// A plan is "active" for 23 hours from the moment it was posted.
// Posting a new plan replaces the old one and starts a fresh 23-hour clock.
// After the timer runs out, the display goes back to the empty state.
function isPlanActive(plan) {
  if (!plan || !plan.postedAt) return false;
  const postedAt = new Date(plan.postedAt);
  const expiresAt = new Date(postedAt.getTime() + 23 * 60 * 60 * 1000);
  return new Date() < expiresAt;
}

async function saveLatestPlan(data) {
  return await storageSet('latest_plan', JSON.stringify(data));
}

// Device-only storage for the cook's handle (each phone keeps its own)
async function deviceGet(key) {
  try { return localStorage.getItem(`ha-d:${key}`); } catch { return memStore[`d:${key}`] || null; }
}
async function deviceSet(key, value) {
  memStore[`d:${key}`] = value;
  try { localStorage.setItem(`ha-d:${key}`, value); } catch {}
  return { ok: true };
}

