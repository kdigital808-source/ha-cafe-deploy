<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#2A2118">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="HĀ Prep">
<meta name="mobile-web-app-capable" content="yes">
<link rel="manifest" href="/manifest.json">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<title>HĀ CAFE Prep</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400,50;9..144,500,50;9..144,600,80;9..144,700,100;9..144,800,100&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --paper: #FBF5E9;
    --paper-warm: #F4EAD3;
    --paper-deep: #EADBBC;
    --ink: #2A2118;
    --ink-soft: #5C4D3E;
    --ink-faint: #9E8D7A;
    --line: #E2D5B8;
    --coral: #DD5944;
    --coral-bg: #FCE8E2;
    --honey: #E5A23F;
    --honey-bg: #FBEFD5;
    --sea: #2E9385;
    --sea-deep: #1F7A6E;
    --sea-bg: #DCEEEA;
    --line-prep: #2E9385;
    --grab: #D4691E;
    --teal: #2E7B8C;
    --shadow-soft: 0 1px 6px rgba(75, 50, 25, 0.05), 0 1px 2px rgba(75, 50, 25, 0.03);
    --shadow-card: 0 1px 0 rgba(75, 50, 25, 0.04), 0 4px 16px rgba(75, 50, 25, 0.06);
    --shadow-pop: 0 8px 28px rgba(75, 50, 25, 0.18);
  }

  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  
  html, body {
    margin: 0;
    padding: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.45;
    overscroll-behavior: none;
    -webkit-font-smoothing: antialiased;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image: url("/bg-0.jpeg");
    background-size: 320px auto;
    background-repeat: repeat;
    opacity: 0.32;
    z-index: 0;
    mix-blend-mode: multiply;
  }

  .app {
    position: relative;
    z-index: 1;
    max-width: 540px;
    margin: 0 auto;
    min-height: 100vh;
    min-height: 100dvh;
    padding-bottom: 24px;
  }

  /* HEADER */
  header {
    padding: 14px 18px;
    background: linear-gradient(135deg, #2A2118 0%, #3D3024 100%);
    color: var(--paper);
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    box-shadow: 0 4px 20px rgba(42, 33, 24, 0.18);
  }
  .brand {
    flex: 1;
    min-width: 0;
    align-self: center;
  }
  .brand-tag {
    display: block;
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 32px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #FF6B1A;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.5);
    font-variation-settings: "opsz" 96, "SOFT" 80;
  }
  .brand-tag #today-stamp {
    display: block;
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 22px;
    color: var(--paper);
    margin-top: 6px;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
    font-variation-settings: "opsz" 48, "SOFT" 100;
  }
  .logo-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
    gap: 4px;
    max-width: 50%;
  }
  .brand-logo {
    display: block;
    height: 56px;
    width: auto;
    filter: brightness(0) invert(1) drop-shadow(0 2px 8px rgba(0, 0, 0, 0.5));
  }
  .proverb-haw {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 11px;
    font-weight: 500;
    line-height: 1.25;
    color: rgba(251, 245, 233, 0.78);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
    text-align: right;
    margin-top: 4px;
    font-variation-settings: "opsz" 18, "SOFT" 100;
  }
  .proverb-eng {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 10px;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0;
    color: rgba(251, 245, 233, 0.5);
    text-align: right;
    font-variation-settings: "opsz" 14, "SOFT" 100;
  }
  .header-action {
    flex-shrink: 0;
    padding: 10px 18px;
    background: var(--paper);
    color: var(--ink);
    border: none;
    border-radius: 999px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.02em;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
    transition: all 0.18s ease;
  }
  .header-action:active { transform: scale(0.96); }
  .header-action.is-cancel {
    background: rgba(251, 245, 233, 0.15);
    color: var(--paper);
    border: 1px solid rgba(251, 245, 233, 0.35);
    box-shadow: none;
  }

  /* CONTENT */
  main { padding: 0 18px; }
  
  .view { display: none; }
  .view.active { display: block; animation: fadein 0.3s ease; }
  #view-plan { padding-bottom: 96px; }
  @keyframes fadein {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* TODAY VIEW — warm welcome banner */
  .day-banner {
    margin: 22px 0 22px;
    padding: 22px 22px 20px;
    background: linear-gradient(135deg, #2A2118 0%, #3D3024 100%);
    color: var(--paper);
    border-radius: 18px;
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }
  .day-banner::after {
    content: '';
    position: absolute;
    top: -40px; right: -40px;
    width: 160px; height: 160px;
    background: radial-gradient(circle, rgba(229, 162, 63, 0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .day-banner-greeting {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 14px;
    opacity: 0.7;
    font-variation-settings: "opsz" 14, "SOFT" 100;
  }
  .day-banner-date {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 30px;
    line-height: 1.05;
    margin-top: 4px;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 96, "SOFT" 80;
  }
  .day-banner-sub {
    font-size: 11px;
    opacity: 0.55;
    margin-top: 6px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .day-banner-progress {
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    font-weight: 600;
  }
  .progress-bar {
    flex: 1;
    height: 6px;
    background: rgba(251, 245, 233, 0.15);
    border-radius: 999px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--honey), var(--paper));
    transition: width 0.4s ease;
    width: 0%;
    border-radius: 999px;
  }

  .priority-section {
    margin-bottom: 26px;
  }
  .priority-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    padding: 0 4px;
  }
  .priority-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 24, "SOFT" 100;
  }
  .priority-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .priority-dot.asap { background: var(--coral); }
  .priority-dot.second { background: var(--honey); }
  .priority-dot.time { background: var(--sea); }
  .priority-count {
    font-size: 12px;
    color: var(--ink-faint);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  
  /* Compact posted-list layout — bulleted, grouped by list */
  .priority-section.compact {
    margin-bottom: 18px;
    padding: 12px 14px 10px;
    background: rgba(255, 252, 244, 0.68);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(226, 213, 184, 0.7);
    border-radius: 14px;
    box-shadow: var(--shadow-soft);
  }
  .priority-section.compact .priority-header {
    margin-bottom: 8px;
    padding: 0;
  }
  .priority-section.compact .priority-title {
    font-size: 16px;
  }
  .compact-section-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .compact-list-group {
    /* sub-group within a priority */
  }
  .compact-list-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 4px;
    padding: 2px 8px;
    border-radius: 999px;
    display: inline-block;
  }
  .compact-list-line {
    background: rgba(46, 147, 133, 0.12);
    color: var(--sea);
  }
  .compact-list-grab {
    background: rgba(229, 162, 63, 0.15);
    color: #B8821C;
  }
  .compact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .compact-list li {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
    padding: 3px 0 3px 14px;
    position: relative;
  }
  .compact-list li::before {
    content: '•';
    position: absolute;
    left: 2px;
    color: var(--ink-faint);
    font-weight: 700;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    background: rgba(255, 252, 244, 0.68);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(226, 213, 184, 0.7);
    border-radius: 14px;
    margin-bottom: 8px;
    cursor: pointer;
    user-select: none;
    transition: all 0.18s ease;
    box-shadow: var(--shadow-soft);
    min-height: 60px;
  }
  .item:active {
    transform: scale(0.985);
  }
  .item.display-only {
    cursor: default;
    padding: 10px 14px;
    min-height: 0;
    margin-bottom: 6px;
  }
  .item.display-only:active {
    transform: none;
  }
  .item.display-only .item-name {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
  }
  .item.display-only .item-meta {
    font-size: 10px;
    margin-top: 2px;
  }
  .item.done {
    background: var(--paper-warm);
    box-shadow: none;
    border-color: var(--paper-deep);
  }
  .item.done .item-name {
    text-decoration: line-through;
    text-decoration-thickness: 2px;
    color: var(--ink-faint);
  }
  
  .checkbox {
    width: 26px;
    height: 26px;
    border: 2px solid var(--ink-faint);
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--paper);
    transition: all 0.2s ease;
  }
  .item.done .checkbox {
    background: var(--sea);
    border-color: var(--sea);
  }
  .checkbox svg {
    width: 14px;
    height: 14px;
    stroke: #fff;
    stroke-width: 3;
    fill: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .item.done .checkbox svg { opacity: 1; }
  
  .item-body {
    flex: 1;
    min-width: 0;
  }
  .item-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.005em;
    line-height: 1.25;
  }
  .item-meta {
    margin-top: 5px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    font-weight: 600;
  }
  .item-tag {
    padding: 3px 8px;
    border-radius: 999px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.1em;
    font-size: 9px;
  }
  .item-tag.line { background: var(--line-prep); }
  .item-tag.grab { background: var(--grab); }
  .item-carry {
    color: var(--coral);
    font-weight: 700;
  }

  .empty-state {
    text-align: center;
    padding: 50px 24px;
    color: var(--ink-soft);
  }
  .empty-state-icon {
    font-family: 'Fraunces', serif;
    font-size: 48px;
    line-height: 1;
    margin-bottom: 12px;
    color: var(--honey);
    opacity: 0.7;
    font-style: italic;
  }
  .empty-state-title {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 22px;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .empty-state-text {
    font-size: 14px;
    color: var(--ink-faint);
    max-width: 280px;
    margin: 0 auto;
    line-height: 1.5;
  }
  .empty-state-cta {
    margin-top: 20px;
    padding: 14px 28px;
    background: #8A6F4F;
    color: var(--paper);
    border: none;
    border-radius: 999px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.02em;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(138, 111, 79, 0.3);
    transition: all 0.18s ease;
  }
  .empty-state-cta:active { transform: scale(0.96); }
  
  .plan-back {
    margin: 16px 0 4px;
    padding: 8px 14px;
    background: transparent;
    border: none;
    color: var(--ink-soft);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    border-radius: 999px;
    transition: background 0.15s ease;
  }
  .plan-back:active { background: var(--paper-warm); }

  /* PLAN VIEW */
  .plan-intro {
    margin: 22px 0 20px;
    padding: 20px;
    background: linear-gradient(135deg, var(--paper-warm), var(--paper-deep));
    border-radius: 18px;
    box-shadow: var(--shadow-soft);
  }
  .plan-intro-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-soft);
    font-weight: 600;
  }
  .plan-intro-title {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 26px;
    margin-top: 8px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 60, "SOFT" 100;
  }
  .target-toggle {
    display: inline-flex;
    margin-top: 8px;
    background: rgba(42, 33, 24, 0.08);
    border-radius: 999px;
    padding: 4px;
    gap: 2px;
  }
  .target-pill {
    padding: 8px 18px;
    background: transparent;
    border: none;
    border-radius: 999px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 0.18s ease;
    letter-spacing: 0.02em;
  }
  .target-pill.active {
    background: var(--ink);
    color: var(--paper);
    box-shadow: 0 2px 8px rgba(42, 33, 24, 0.2);
  }
  .target-pill:active { transform: scale(0.96); }
  .plan-intro-help {
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 10px;
    line-height: 1.5;
  }
  .plan-intro-reset {
    display: inline-block;
    margin-top: 12px;
    padding: 5px 11px;
    background: rgba(255, 107, 26, 0.12);
    color: #C5460A;
    border: 1px solid rgba(197, 70, 10, 0.3);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .plan-intro-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 12px;
  }
  .plan-intro-meta .plan-intro-reset {
    margin-top: 0;
  }
  
  .instructions-block {
    margin: 0 0 18px;
    padding: 14px 16px 16px;
    background: rgba(255, 252, 244, 0.68);
    border: 1.5px solid var(--line);
    border-radius: 14px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .instructions-label {
    display: block;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: 0.01em;
    margin-bottom: 8px;
  }
  .instructions-optional {
    font-weight: 500;
    font-size: 11px;
    color: var(--ink-faint);
    text-transform: none;
    letter-spacing: 0;
  }
  .instructions-textarea {
    width: 100%;
    padding: 10px 12px;
    background: rgba(255, 252, 244, 0.85);
    border: 1.5px solid var(--line);
    border-radius: 10px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    line-height: 1.45;
    color: var(--ink);
    resize: vertical;
    min-height: 60px;
    outline: none;
    transition: border-color 0.18s ease;
    box-sizing: border-box;
  }
  .instructions-textarea:focus {
    border-color: var(--sea);
  }
  .instructions-textarea::placeholder {
    color: var(--ink-faint);
    font-weight: 400;
  }
  
  .instructions-banner {
    margin: 0 0 16px;
    padding: 14px 16px;
    background: rgba(255, 247, 224, 0.85);
    border: 1.5px solid #E5A23F;
    border-left-width: 5px;
    border-radius: 12px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .instructions-banner-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #B8821C;
    margin-bottom: 6px;
  }
  .instructions-banner-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink);
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .handle-display {
    padding: 5px 11px;
    background: var(--ink);
    color: var(--paper);
    border: none;
    border-radius: 999px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .handle-display:active { transform: scale(0.95); }
  .handle-display.unset {
    background: transparent;
    color: var(--ink-soft);
    border: 1px dashed var(--ink-faint);
  }

  /* HANDLE INPUT */
  .handle-help {
    font-size: 13px;
    color: var(--ink-soft);
    text-align: center;
    margin: -8px 0 16px;
    line-height: 1.4;
  }
  .handle-input-wrap {
    display: flex;
    align-items: center;
    background: rgba(255, 252, 244, 0.85);
    border: 1.5px solid var(--line);
    border-radius: 12px;
    padding: 4px 4px 4px 14px;
    margin-bottom: 16px;
    transition: border-color 0.18s ease;
  }
  .handle-input-wrap:focus-within {
    border-color: var(--sea);
  }
  .handle-prefix {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 22px;
    color: var(--ink-faint);
    margin-right: 4px;
  }
  .handle-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 14px 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 17px;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .handle-input::placeholder {
    color: var(--ink-faint);
    font-weight: 500;
  }

  .category-section {
    margin-bottom: 22px;
  }
  .category-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    padding: 0 4px 8px;
    border-bottom: 1px solid var(--line);
  }
  .category-name {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 24, "SOFT" 100;
  }
  .category-list {
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 999px;
    color: #fff;
    letter-spacing: 0.12em;
    font-weight: 700;
    text-transform: uppercase;
  }
  .category-list.line { background: var(--line-prep); }
  .category-list.grab { background: var(--grab); }

  .plan-item {
    display: flex;
    align-items: center;
    gap: 12px;
