// 6pm daily reset — returns the most recent 6pm boundary
function lastResetTime() {
  const now = new Date();
  const todaySix = new Date(now);
  todaySix.setHours(18, 0, 0, 0);
  if (now >= todaySix) return todaySix;
  const yest = new Date(todaySix);
  yest.setDate(yest.getDate() - 1);
  return yest;
}

function nextResetTime() {
  const now = new Date();
  const todaySix = new Date(now);
  todaySix.setHours(18, 0, 0, 0);
  if (now < todaySix) return todaySix;
  const tom = new Date(todaySix);
  tom.setDate(tom.getDate() + 1);
  return tom;
}

async function loadDraft() {
  const raw = await storageGet('plan_draft');
  if (!raw) return null;
  try {
    const { draft, savedAt } = JSON.parse(raw);
    if (new Date(savedAt) < lastResetTime()) return null; // stale, post-6pm boundary
    return draft;
  } catch { return null; }
}

async function saveDraft(draft) {
  return await storageSet('plan_draft', JSON.stringify({
    draft,
    savedAt: new Date().toISOString()
  }));
}

async function clearDraft() {
  return await storageSet('plan_draft', JSON.stringify({ draft: {}, savedAt: new Date().toISOString() }));
}

