function targetKey() {
  return planTarget === 'today' ? todayKey() : tomorrowKey();
}

function refreshTargetUI() {
  document.getElementById('plan-target-date').textContent = prettyDate(targetKey());
}

async function renderPlan() {
  // Group items by list, then category
  const grouped = {};
  MASTER_ITEMS.forEach(item => {
    const listKey = item.list;
    if (!grouped[listKey]) grouped[listKey] = {};
    if (!grouped[listKey][item.category]) grouped[listKey][item.category] = [];
    grouped[listKey][item.category].push(item);
  });

  const target = document.getElementById('plan-content');
  let html = '';

  ['line', 'grab'].forEach(listKey => {
    const listLabel = listKey === 'line' ? 'LINE PREP' : "GRAB & GO'S";
    const categories = grouped[listKey];
    const order = listKey === 'line'
      ? ['MEAT', 'VEGAN MEAT', 'SAUCES', 'BREAD', 'VEGETABLES']
      : ['MEAT', 'VEGETABLES', 'SAUCES'];

    order.forEach(cat => {
      if (!categories[cat]) return;
      html += `
        <div class="category-section">
          <div class="category-header">
            <span class="category-list ${listKey}">${listLabel}</span>
            <span class="category-name">${cat}</span>
          </div>
          ${categories[cat].map(item => {
            const priority = planDraft[item.id];
            const badgeHtml = priority
              ? `<div class="plan-priority-badge ${priority}">${PRIORITY_LABELS[priority]}</div>`
              : `<div class="plan-priority-badge add">+</div>`;
            return `
              <div class="plan-item priority-${priority || 'skip'}" onclick="openPicker('${item.id}')">
                <div>
                  <div class="plan-item-name">${item.name}</div>
                </div>
                ${badgeHtml}
              </div>
            `;
          }).join('')}
        </div>
      `;
    });
  });

  target.innerHTML = html;
  updatePostBar();
}

function updatePostBar() {
  const count = Object.values(planDraft).filter(p => p !== 'skip').length;
  const bar = document.getElementById('post-bar');
  const btn = document.getElementById('post-button');
  document.getElementById('post-count').textContent = count;
  if (activeView === 'plan' && count > 0) {
    bar.style.display = 'block';
    btn.disabled = false;
  } else if (activeView === 'plan') {
    bar.style.display = 'block';
    btn.disabled = true;
  } else {
    bar.style.display = 'none';
  }
}

