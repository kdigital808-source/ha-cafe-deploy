async function copyOoi() {
  const text = document.getElementById('ooi-textarea').value.trim();
  if (!text) {
    showToast('Nothing to copy');
    return;
  }
  try {
    await navigator.clipboard.writeText(text);
    const btn = document.getElementById('ooi-copy');
    btn.textContent = '✓ Copied';
    btn.classList.add('copied');
    showToast('Copied — paste into Break Room');
    setTimeout(() => {
      btn.textContent = 'Copy list';
      btn.classList.remove('copied');
    }, 2000);
  } catch {
    // Fallback for older browsers
    const ta = document.getElementById('ooi-textarea');
    ta.select();
    document.execCommand('copy');
    showToast('Copied');
  }
}

async function clearOoi() {
