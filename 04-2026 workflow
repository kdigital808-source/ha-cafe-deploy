function openConfirm() {
  const counts = { asap: 0, second: 0, time: 0 };
  Object.values(planDraft).forEach(p => { if (counts[p] !== undefined) counts[p]++; });
  const total = counts.asap + counts.second + counts.time;
  if (total === 0) return;

  // Require a handle before posting
  if (!cookHandle) {
    pendingPostAfterHandle = true;
    openHandleModal();
    return;
  }

  document.getElementById('confirm-date').textContent = prettyDate(targetKey());
  document.getElementById('confirm-summary').innerHTML = `
    <div class="confirm-row">
      <span>● ASAP</span>
      <span>${counts.asap} item${counts.asap === 1 ? '' : 's'}</span>
    </div>
    <div class="confirm-row">
      <span>● 2nd Priority</span>
      <span>${counts.second} item${counts.second === 1 ? '' : 's'}</span>
    </div>
    <div class="confirm-row">
      <span>● If You Have Time</span>
      <span>${counts.time} item${counts.time === 1 ? '' : 's'}</span>
    </div>
    <div class="confirm-row" style="font-weight:700;border-top:1.5px solid var(--ink);margin-top:4px;padding-top:8px">
      <span>TOTAL</span>
      <span>${total} items</span>
    </div>
  `;
  document.getElementById('confirm-modal').classList.add('show');
}

async function doPostPlan() {
  const target = targetKey();
  
  const filtered = MASTER_ITEMS
    .filter(i => planDraft[i.id] && planDraft[i.id] !== 'skip')
    .map(i => ({
      ...i,
      priority: planDraft[i.id],
    }));
  
  filtered.sort((a, b) => {
    const pd = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];
    if (pd !== 0) return pd;
    const ld = a.list.localeCompare(b.list);
    if (ld !== 0) return ld;
    const cd = a.category.localeCompare(b.category);
    if (cd !== 0) return cd;
    return a.name.localeCompare(b.name);
  });

  const instructionsText = (document.getElementById('plan-instructions').value || '').trim();

  const data = {
    targetDate: target,
    postedAt: new Date().toISOString(),
    postedBy: cookHandle || null,
    items: filtered,
    instructions: instructionsText || null,
  };

  const ok = await saveLatestPlan(data);
  document.getElementById('confirm-modal').classList.remove('show');
  
  if (ok && ok.ok) {
    const modeNote = ok.mode === 'shared' ? '' : ok.mode === 'private' ? ' (this device)' : ' (session only)';
    showToast(`Mahalo — ${filtered.length} items sent for ${shortDate(target)}${modeNote}`);
    planDraft = {};
    await clearDraft();
    switchView('display');
  } else {
    showToast('Save failed — check console');
  }
}

// ═══════════════════════════════════════════════════════════════
// VIEW SWITCHING
// ═══════════════════════════════════════════════════════════════
async function switchView(view) {
  activeView = view;
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById(`view-${view}`).classList.add('active');
  document.body.classList.toggle('planning', view === 'plan');

  if (view === 'display') {
    renderDisplay();
  } else if (view === 'plan') {

    // Smart default for target date:
    // If the latest posted plan is for today or tomorrow already, default to "tomorrow" (normal evening planning).
    // If latest plan is for yesterday or older (or none exists), default to "today" — catches the morning-of forgot case.
    const latest = await loadLatestPlan();
    planTarget = 'tomorrow';

    // Try saved draft first, fall back to pre-filling from latest posted plan
    const savedDraft = await loadDraft();
    if (savedDraft && Object.keys(savedDraft).length > 0) {
      planDraft = savedDraft;
    } else {
      planDraft = {};
      if (latest && latest.items) {
        latest.items.forEach(it => {
          planDraft[it.id] = it.priority;
        });
      }
    }
    
    // Pre-fill instructions field from latest posted plan
    const instructionsEl = document.getElementById('plan-instructions');
    if (instructionsEl) {
      instructionsEl.value = (latest && latest.instructions) ? latest.instructions : '';
    }
    
    refreshTargetUI();
    renderPlan();
  }
  updatePostBar();
  window.scrollTo(0, 0);
}

// ═══════════════════════════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════════════════════════
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2500);
}

// ═══════════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════════
function setHeaderDate() {
  document.getElementById('today-stamp').textContent = shortDate(tomorrowKey());
}
setHeaderDate();

document.querySelectorAll('.priority-option').forEach(opt => {
  opt.addEventListener('click', () => setPriority(opt.dataset.priority));
});

document.getElementById('modal-cancel').addEventListener('click', closePicker);
document.getElementById('modal-remove').addEventListener('click', () => setPriority('skip'));
document.getElementById('priority-modal').addEventListener('click', closePicker);

document.getElementById('post-button').addEventListener('click', openConfirm);
document.getElementById('confirm-cancel').addEventListener('click', () => {
  document.getElementById('confirm-modal').classList.remove('show');
});
document.getElementById('confirm-modal').addEventListener('click', () => {
  document.getElementById('confirm-modal').classList.remove('show');
});
document.getElementById('confirm-post').addEventListener('click', doPostPlan);

// Handle modal
document.getElementById('handle-cancel').addEventListener('click', closeHandleModal);
document.getElementById('handle-modal').addEventListener('click', closeHandleModal);
document.getElementById('handle-save').addEventListener('click', submitHandle);
document.getElementById('handle-input').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') submitHandle();
});

// Out of items
document.getElementById('ooi-textarea').addEventListener('input', debouncedSaveOoi);
document.getElementById('ooi-copy').addEventListener('click', copyOoi);
document.getElementById('ooi-clear').addEventListener('click', clearOoi);
document.getElementById('ooi-modal').addEventListener('click', closeOoiModal);

(async () => {
  await loadHandle();
  updateHandleUI();
  await updateOoiBadge();
})();

renderDisplay();
</script>
</body>
